<Window x:Class="TriangleWPF.MainWindow" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
        Title="Triangle Calculator" Height="600" Width="300">
     <StackPanel Margin="20">
         <TextBlock Text="Треугольник 1"/>
         <TextBlock Text="Сторона A:"/> 
         <TextBox x:Name="txtA1" Margin="0,5"/> 
         <TextBlock Text="Сторона B:"/> 
         <TextBox x:Name="txtB1" Margin="0,5"/> 
         <TextBlock Text="Сторона C:"/> 
         <TextBox x:Name="txtC1" Margin="0,5"/> 
         <TextBlock Text="Треугольник 2"/>
         <TextBlock Text="Сторона A:"/> 
         <TextBox x:Name="txtA2" Margin="0,5"/> 
         <TextBlock Text="Сторона B:"/> 
         <TextBox x:Name="txtB2" Margin="0,5"/> 
         <TextBlock Text="Сторона C:"/> 
         <TextBox x:Name="txtC2" Margin="0,5"/> 
         <Button Content="Рассчитать" Click="btnCalculate_Click" Margin="0,15"/> 
         <TextBlock x:Name="lblResult11" FontWeight="Bold"/>
         <TextBlock x:Name="lblResult12" FontWeight="Bold"/>
         <TextBlock x:Name="lblResult21" FontWeight="Bold"/>
         <TextBlock x:Name="lblResult22" FontWeight="Bold"/>
         <TextBlock x:Name="lblResult31" FontWeight="Bold"/>
     </StackPanel>
</Window>
